ENV=development

# --- Gemini (Google GenAI SDK) -----------------------------------------
# Server-side only. Never commit the real value or ship it in the mobile bundle.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ------------------------------------------------------------
# service_role key bypasses Row Level Security — backend only, never the app.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_BUCKET=recordings
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Recording limits ------------------------------------------------------
RECOMMENDED_MIN_SECONDS=60
RECOMMENDED_MAX_SECONDS=120
MAX_RECORDING_SECONDS=120

# --- Abuse / cost control --------------------------------------------------
MAX_DAILY_RECORDINGS=10
MAX_UPLOAD_SIZE_MB=10

# --- CORS --------------------------------------------------------------
# Comma-free JSON-style list is not supported by pydantic-settings list parsing
# from plain env vars by default; for dev keep "*" or set via a proper list source.
ALLOWED_ORIGINS=["*"]
