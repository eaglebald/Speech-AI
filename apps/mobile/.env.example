# Only non-secret, client-safe values belong here. EXPO_PUBLIC_* vars are
# inlined into the JS bundle at build time and are extractable by anyone who
# has the app installed — never put API keys (Gemini, Supabase service_role) here.

EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# --- Supabase (anon/publishable key only — this one is meant to be public) ---
# Same project as the backend's SUPABASE_URL. Find both in Supabase dashboard
# > Project Settings > API. Enable Authentication > Providers > Anonymous
# Sign-Ins for signInAnonymously() to work.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
